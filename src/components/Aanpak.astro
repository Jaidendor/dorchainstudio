---
const stappen = [
  { n: '01', t: 'Gratis scan', d: 'Je stuurt me de link naar je website. Ik loop hem na op snelheid, vindbaarheid, ontwerp en toegankelijkheid en stuur je een eerlijk overzicht.' },
  { n: '02', t: 'Plan & prijs', d: 'Je krijgt een helder voorstel: wat ik aanpak, wat het oplevert en wat het kost. Geen verrassingen achteraf.' },
  { n: '03', t: 'Aan de slag', d: 'Ik verbeter je site stap voor stap. Jij hoeft niets technisch te doen. Ik houd je op de hoogte van wat er verandert.' },
  { n: '04', t: 'Live & uitleg', d: 'Je vernieuwde site gaat online. Ik leg in gewone taal uit wat ik heb gedaan, zodat je zelf snapt wat er beter is.' },
];
---
<section class="section aanpak" id="aanpak">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow eyebrow--dark">Aanpak</p>
      <h2>Van rommelige site naar iets om trots op te zijn.</h2>
      <p>Vier stappen. Jij houdt de regie, ik doe het werk.</p>
    </div>

    <ol class="aanpak__steps">
      {stappen.map((s, i) => (
        <li class="aanpak__step reveal" style={`--delay:${i * 90}ms`}>
          <span class="aanpak__num">{s.n}</span>
          <div class="aanpak__body">
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .aanpak { background: var(--dark); color: var(--on-dark); border-radius: clamp(24px, 3vw, 40px); }
  .aanpak .section-head h2 { color: var(--paper); }
  .aanpak .section-head p { color: var(--on-dark-soft); }
  .eyebrow--dark { color: var(--accent); }
  .eyebrow--dark::before { background: var(--accent); }

  .aanpak__steps {
    list-style: none; padding: 0; margin: 0; counter-reset: none;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
  }
  .aanpak__step { position: relative; padding-top: 2rem; border-top: 1px solid var(--dark-line); }
  .aanpak__step::before {
    content: ''; position: absolute; top: -1px; left: 0; width: 2.5rem; height: 2px;
    background: var(--accent);
  }
  .aanpak__num {
    font-family: var(--font-mono); font-size: 0.95rem; color: var(--accent);
    letter-spacing: 0.1em;
  }
  .aanpak__body h3 { color: var(--paper); font-size: var(--text-h3); margin: 0.9rem 0 0.6rem; }
  .aanpak__body p { color: var(--on-dark-soft); font-size: 0.98rem; }

  @media (max-width: 900px) { .aanpak__steps { grid-template-columns: repeat(2, 1fr); gap: 1.75rem; } }
  @media (max-width: 560px) { .aanpak__steps { grid-template-columns: 1fr; } }
</style>
