---
const diensten = [
  { n: '01', t: 'Styling & ontwerp', d: 'Een uiterlijk dat past bij jouw werk. Rustige kleuren, leesbare tekst en een indeling die bezoekers meteen snappen.', big: false },
  { n: '02', t: 'Vindbaarheid in Google', d: 'Ik richt je titels, teksten en techniek zo in dat klanten je vinden wanneer ze zoeken naar wat jij doet.', big: false },
  { n: '03', t: 'Snelheid', d: 'Een site die laadt voordat iemand wegklikt. Ik verklein afbeeldingen, ruim code op en haal de rem eraf.', big: false },
  { n: '04', t: 'Toegankelijkheid', d: 'Bruikbaar voor iedereen, ook met een schermlezer of toetsenbord. Goed voor je bezoekers en voor Google.', big: false },
  { n: '05', t: 'Mobiel & desktop', d: 'Werkt net zo goed op een telefoon als op een breed scherm. Geen knoppen die je net niet kunt raken.', big: false },
];
---
<section class="section dst" id="diensten">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Wat ik doe</p>
      <h2>Vijf dingen die je website beter maken.</h2>
      <p>Je kiest waar je hulp bij wilt, of je laat me alles oppakken. Aan jou de keuze.</p>
    </div>

    <div class="dst__grid">
      {diensten.map((s, i) => (
        <article class="dst__card reveal" style={`--delay:${i * 60}ms`}>
          <span class="dst__num">{s.n}</span>
          <h3>{s.t}</h3>
          <p>{s.d}</p>
        </article>
      ))}

      <article class="dst__card dst__card--big reveal" style="--delay:120ms">
        <span class="dst__num">+</span>
        <h3>Of je hele site opnieuw</h3>
        <p>
          Soms is opknappen niet genoeg. Dan bouw ik je website opnieuw op, met alle
          punten hierboven er meteen goed in. Jij vertelt wat je nodig hebt, ik regel
          de rest.
        </p>
        <a class="dst__link" href="#contact">Bespreek de mogelijkheden <span aria-hidden="true">&rarr;</span></a>
      </article>
    </div>
  </div>
</section>

<style>
  .dst__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
  .dst__card {
    position: relative; padding: clamp(1.4rem, 1rem + 1vw, 2rem);
    background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg);
    transition: transform 0.3s var(--ease), border-color 0.3s, box-shadow 0.3s;
  }
  .dst__card:hover {
    transform: translateY(-4px); border-color: var(--accent-strong);
    box-shadow: 0 20px 40px -28px oklch(46% 0.12 152 / 0.5);
  }
  .dst__num {
    display: inline-block; font-family: var(--font-mono); font-size: 0.85rem;
    color: var(--accent-deep); letter-spacing: 0.05em; margin-bottom: 1.4rem;
    padding: 0.25em 0.55em; border: 1px solid var(--line); border-radius: 8px;
  }
  .dst__card h3 { font-size: var(--text-h3); margin-bottom: 0.6rem; }
  .dst__card p { color: var(--ink-soft); }
  .dst__card--big {
    grid-column: span 1; background: var(--dark); color: var(--on-dark);
    border-color: var(--dark-line);
  }
  .dst__card--big h3 { color: var(--paper); }
  .dst__card--big p { color: var(--on-dark-soft); }
  .dst__card--big .dst__num { color: var(--accent); border-color: var(--dark-line); background: var(--dark-2); }
  .dst__card--big:hover { border-color: var(--accent); }
  .dst__link {
    display: inline-flex; gap: 0.5em; margin-top: 1.3rem; font-weight: 600;
    color: var(--accent); text-decoration: none;
  }
  .dst__link:hover { text-decoration: underline; }

  @media (max-width: 900px) { .dst__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .dst__grid { grid-template-columns: 1fr; } }
</style>
